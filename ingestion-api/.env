PORT=4000
REDIS_URL=redis://localhost:6379
MONGODB_URI=mongodb+srv://REPLACE_USER:REPLACE_PASS@cluster.mongodb.net/logaggregator?retryWrites=true&w=majority

# AWS credentials (leave as-is if not using S3/SNS — will be skipped automatically)
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1
S3_BUCKET=log-archive-demo
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789:log-alerts

# Alerting thresholds
ERROR_ALERT_THRESHOLD=10
ERROR_ALERT_WINDOW_MS=60000

# Archive settings
ARCHIVE_AFTER_DAYS=7

# Internal auth key for worker→server communication
INTERNAL_KEY=worker-secret-change-in-production
